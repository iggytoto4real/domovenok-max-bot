# URL бэкенда (backend-core). Для локальной разработки с бэкендом — http://localhost:8080
# В проде укажи HTTPS URL твоего API, например https://api.example.com
VITE_API_URL=http://localhost:8080

# Режим «фейковые данные в MAX»: при открытии из MAX не вызывать бэкенд, показывать фейковых пользователя и домовят.
# true = сборка для проверки в MAX без деплоя бэка (пользователь берётся из initDataUnsafe, питомцы — фейковые).
# Можно также включить через URL: ?fake=1 или ?fake=true
# VITE_USE_FAKE_IN_MAX=true
